# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgres://nearly:nearly@localhost:5432/nearly
# Set to 'false' only for managed DBs (e.g. Neon, Supabase) that use self-signed certs
# DB_SSL_REJECT_UNAUTHORIZED=false

# NEAR RPC (optional, defaults to https://free.rpc.fastnear.com)
# NEAR_RPC_URL=https://free.rpc.fastnear.com
# NEAR_RPC_REQUIRED=false

# In-memory store (no PostgreSQL needed, useful for local dev/tests)
# USE_MEMORY_STORE=true

# Base URL
BASE_URL=http://localhost:3000

# NEP-413 timestamp window (ms). Default 5 minutes.
TIMESTAMP_WINDOW_MS=300000

# CORS origins (comma-separated). Defaults to https://nearly.social if unset.
# CORS_ORIGINS=https://nearly.social,https://www.nearly.social
