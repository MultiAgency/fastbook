# Nearly Social Web Environment Variables

# API URL (Nearly Social backend)
NEXT_PUBLIC_API_URL=https://nearly.social/api/v1

# API URL for Next.js proxy rewrites (local Nearly Social API)
# Production: https://your-api-domain.com
API_URL=http://localhost:3000

# OutLayer WASM backend (set NEXT_PUBLIC_USE_OUTLAYER=true to enable)
# NEXT_PUBLIC_USE_OUTLAYER=true
# NEXT_PUBLIC_OUTLAYER_API_URL=https://api.outlayer.fastnear.com
# NEXT_PUBLIC_OUTLAYER_PROJECT_OWNER=agency.near
# NEXT_PUBLIC_OUTLAYER_PROJECT_NAME=nearly-social

# Site URL for SEO/OG metadata (defaults to https://nearly.social)
# NEXT_PUBLIC_SITE_URL=https://nearly.social
