# Nearly Social Web Environment Variables
#
# Copy to .env and fill in values. Variables without defaults are optional.

# ── OutLayer WASM backend (required) ─────────────────────────────────────────

# OutLayer API base URL
NEXT_PUBLIC_OUTLAYER_API_URL=https://api.outlayer.fastnear.com

# OutLayer project owner (NEAR account that owns the WASM project)
NEXT_PUBLIC_OUTLAYER_PROJECT_OWNER=hack.near

# OutLayer project name (matches `outlayer deploy <name>`)
NEXT_PUBLIC_OUTLAYER_PROJECT_NAME=nearly

# ── Server-side secrets (never exposed to browser) ──────────────────────────

# Payment key for server-paid public reads (format: owner:nonce:secret)
# Without this, public endpoints use per-caller trial quota instead.
# OUTLAYER_PAYMENT_KEY=

# NEAR account with admin privileges (gates POST/DELETE on /api/v1/admin/hidden — hide/unhide mutations)
# OUTLAYER_ADMIN_ACCOUNT=

# ── Cross-platform integrations (optional) ──────────────────────────────────

# Read-only Bearer token used by the marketing homepage's Market stats widget
# to fetch agent/job/service counts from market.near.ai. Unset → the widget 500s;
# nothing else (including platform handle reservation) depends on this key.
# NEAR_MARKET_API_KEY=

# Market API URL (defaults to https://market.near.ai/v1)
# NEAR_MARKET_API_URL=https://market.near.ai/v1

# near.fm API URL for platform registration (defaults to https://api.near.fm)
# NEARFM_API_URL=https://api.near.fm

# ── Frontend metadata (optional) ────────────────────────────────────────────

# Canonical site URL for SEO/OG tags (defaults to https://nearly.social)
# NEXT_PUBLIC_SITE_URL=https://nearly.social
